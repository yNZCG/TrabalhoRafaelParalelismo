#include <iostream>
#include <vector>
#include <queue>
#include <fstream>
#include <chrono>
#include <climits>
#include <cstdlib>
#include <iomanip>
#include <omp.h>
using namespace std;
struct Edge {
    int to;
    int weight;
};
typedef pair<int, int> pii;
class Graph {
private:
    int V;
    vector<vector<Edge>> adj;
public:
    Graph(int vertices) {
        V = vertices;
        adj.resize(V);
    }
    void addEdge(int u, int v, int w) {
        adj[u].push_back({v, w});
        adj[v].push_back({u, w}); // grafo não direcionado
    }
    vector<int> dijkstra(int source) {
        vector<int> dist(V, INT_MAX);
        priority_queue<
            pii,
            vector<pii>,
            greater<pii>
        > pq;
        dist[source] = 0;
        pq.push({0, source});
        while (!pq.empty()) {
            int currentDist = pq.top().first;
            int u = pq.top().second;
            pq.pop();
            if (currentDist > dist[u])
                continue;
            for (const auto &edge : adj[u]) {
                int v = edge.to;
                int w = edge.weight;
                if (dist[u] != INT_MAX &&
                    dist[u] + w < dist[v]) {
                    dist[v] = dist[u] + w;
                    pq.push({dist[v], v});
                }
            }
        }
        return dist;
    }
};
double executarExperimento(
    Graph &g,
    const vector<int> &origins,
    int numThreads)
{
    omp_set_num_threads(numThreads);
    vector<vector<int>> resultados(origins.size());
    auto inicio =
        chrono::high_resolution_clock::now();
    #pragma omp parallel for schedule(dynamic)
    for (int i = 0; i < (int)origins.size(); i++) {
        resultados[i] =
            g.dijkstra(origins[i]);
    }
    auto fim =
        chrono::high_resolution_clock::now();
    return chrono::duration<double>(
        fim - inicio).count();
}
int main() {
    ifstream file("grafo.txt");
    if (!file.is_open()) {
        cout << "Erro ao abrir o arquivo grafo.txt" << endl;
        return 1;
    }
    int V, E;
    file >> V >> E;
    Graph g(V);
    for (int i = 0; i < E; i++) {
        int u, v, w;
        file >> u >> v >> w;
        g.addEdge(u, v, w);
    }
    file.close();
    cout << "=============================================\n";
    cout << "OTIMIZACAO DE ROTAS DE EVACUACAO - BH\n";
    cout << "Programacao Paralela com OpenMP\n";
    cout << "=============================================\n\n";
    cout << "Vertices: " << V << endl;
    cout << "Arestas : " << E << endl;
    const int NUM_ORIGINS = 4000;
    vector<int> origins(NUM_ORIGINS);
    srand(42);
    for (int i = 0; i < NUM_ORIGINS; i++) {
        origins[i] = rand() % V;
    }
    cout << "Consultas simultaneas: "
         << NUM_ORIGINS << endl << endl;
    // Testes até 12 threads
    vector<int> threads = {1, 2, 4, 8, 12};
    double tempoSerial = 0.0;
    cout << fixed << setprecision(2);
    cout << "-----------------------------------------------------------\n";
    cout << "Threads\tTempo(s)\tSpeedup\t\tEficiencia\n";
    cout << "-----------------------------------------------------------\n";
    for (int t : threads) {
        double tempo =
            executarExperimento(g, origins, t);
        if (t == 1)
            tempoSerial = tempo;
        double speedup =
            tempoSerial / tempo;
        double eficiencia =
            (speedup / t) * 100.0;
        cout << t
             << "\t"
             << tempo
             << "\t\t"
             << speedup
             << "x\t\t"
             << eficiencia
             << "%\n";
    }
    cout << "-----------------------------------------------------------\n";
    return 0;
}
